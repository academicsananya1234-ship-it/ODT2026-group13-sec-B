from machine import Pin   # import Pin so we can read the sensors
import time               # import time so we can measure delays

sensor1 = Pin(34, Pin.IN, Pin.PULL_UP)   # IR sensor for 1 rupee path
sensor2 = Pin(35, Pin.IN, Pin.PULL_UP)   # IR sensor for 2 rupee path

coin1 = 0   # count of 1 rupee coins
coin2 = 0   # count of 2 rupee coins

last1 = 0   # time of last 1 rupee detection
last2 = 0   # time of last 2 rupee detection

def s1_irq(pin):   # function runs when sensor1 is triggered
    global coin1, last1   # use the variables outside this function
    now = time.ticks_ms()   # get current time in milliseconds
    if time.ticks_diff(now, last1) > 200:   # ignore repeated noise for 200 ms
        coin1 += 1   # add one count for 1 rupee
        last1 = now   # save the time of this detection
        print("1 rupee coin detected")   # show message

def s2_irq(pin):   # function runs when sensor2 is triggered
    global coin2, last2   # use the variables outside this function
    now = time.ticks_ms()   # get current time in milliseconds
    if time.ticks_diff(now, last2) > 200:   # ignore repeated noise for 200 ms
        coin2 += 1   # add one count for 2 rupee
        last2 = now   # save the time of this detection
        print("2 rupee coin detected")   # show message

sensor1.irq(trigger=Pin.IRQ_FALLING, handler=s1_irq)   # attach interrupt to sensor1
sensor2.irq(trigger=Pin.IRQ_FALLING, handler=s2_irq)   # attach interrupt to sensor2

while True:   # keep running forever
    print("Total 1 rupee:", coin1, "Total 2 rupee:", coin2)   # show counts
    time.sleep(1)   # wait 1 second before printing again
